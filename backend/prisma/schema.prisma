generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Identity ─────────────────────────────────────────────────────────────────

model User {
  id                       String    @id @default(uuid())
  githubId                 String?   @unique
  login                    String    @unique
  name                     String?
  avatarUrl                String?
  email                    String?   @unique
  passwordHash             String?
  githubAccessToken        String?
  githubConnectedAt        DateTime?
  // Token health probe state — set by lazy probe when the user or an
  // ops dashboard asks. Null means "not yet checked".
  githubTokenLastCheckedAt DateTime?
  githubTokenHealthy       Boolean?

  // Agent delegation consent (opt-in, default false)
  allowAgentPrCreate  Boolean @default(false)
  allowAgentPrMerge   Boolean @default(false)
  allowAgentPrComment Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships            TeamMember[]
  identities             UserIdentity[]
  agentTokens            AgentToken[]
  tasks                  Task[]          @relation("TaskCreator")
  claims                 Task[]          @relation("TaskClaimant")
  reviews                Task[]          @relation("TaskReviewer")
  signals                Signal[]        @relation("SignalRecipientUser")
  comments               Comment[]       @relation("CommentAuthor")
  artifacts              TaskArtifact[]  @relation("ArtifactCreator")
  attachmentsCreated     TaskAttachment[] @relation("AttachmentCreator")
  auditLogs              AuditLog[]
  projectMemberships     ProjectMember[] @relation("ProjectMemberUser")
  projectMembersInvited  ProjectMember[] @relation("ProjectMemberInviter")
  projectInvitesCreated  ProjectInvite[] @relation("ProjectInviteCreator")
  projectInvitesConsumed ProjectInvite[] @relation("ProjectInviteConsumer")

  @@map("users")
}

// ── Teams ────────────────────────────────────────────────────────────────────

model Team {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       TeamMember[]
  projects      Project[]
  tokens        AgentToken[]
  ssoConnection SsoConnection?

  @@map("teams")
}

// ── SSO (OIDC) ───────────────────────────────────────────────────────────────

model SsoConnection {
  id              String   @id @default(uuid())
  teamId          String   @unique
  // Display label shown to users ("Acme Okta")
  displayName     String
  // OIDC issuer URL — used for discovery (.well-known/openid-configuration)
  issuer          String
  clientId        String
  // Encrypted at rest with SSO_ENCRYPTION_KEY (AES-256-GCM)
  clientSecretEnc String
  // Comma-separated list of email domains this IdP is authoritative for
  // (used for domain-based discovery from the login page).
  emailDomains    String[] @default([])
  // Auto-provision new users on first login (default: true)
  autoProvision   Boolean  @default(true)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([enabled])
  @@map("sso_connections")
}

// ── Federated Identities ─────────────────────────────────────────────────────

model UserIdentity {
  id              String   @id @default(uuid())
  userId          String
  // "github" | "oidc"
  provider        String
  // Stable subject identifier from the IdP (GitHub id, OIDC "sub")
  providerUserId  String
  // For OIDC: the SsoConnection that minted this identity (null for github)
  ssoConnectionId String?
  email           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("user_identities")
}

model TeamMember {
  id        String     @id @default(uuid())
  teamId    String
  userId    String
  role      MemberRole @default(HUMAN_MEMBER)
  createdAt DateTime   @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

enum MemberRole {
  ADMIN
  HUMAN_MEMBER
  REVIEWER
}

// ── Agent Tokens ─────────────────────────────────────────────────────────────

model AgentToken {
  id          String    @id @default(uuid())
  teamId      String
  createdById String
  name        String
  tokenHash   String    @unique
  scopes      String[]  @default([])
  revokedAt   DateTime?
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  team      Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy User           @relation(fields: [createdById], references: [id])
  tasks     Task[]         @relation("TaskAgentCreator")
  claims    Task[]         @relation("TaskAgentClaimant")
  reviews   Task[]         @relation("TaskAgentReviewer")
  signals   Signal[]       @relation("SignalRecipientAgent")
  comments  Comment[]      @relation("CommentAgentAuthor")
  artifacts TaskArtifact[] @relation("ArtifactAgentCreator")

  @@map("agent_tokens")
}

// ── Projects ─────────────────────────────────────────────────────────────────

model Project {
  id                       String          @id @default(uuid())
  teamId                   String
  name                     String
  slug                     String
  description              String?
  githubRepo               String? // "owner/repo" if synced from GitHub
  githubSyncAt             DateTime?
  taskTemplate             Json? // { fields: { goal, acceptanceCriteria, context, constraints, scope, outOfScope, dependencies, risk, agentPrompt: bool }, presets: [...] }
  confidenceThreshold      Int             @default(60) // 0-100, minimum confidence score for agent claims
  // scorer-v2 (T5): per-project confidence-gate enforcement. Nullable; null
  // resolves to WARN via resolveEnforcementMode() so existing rows roll out in
  // warn-mode without a backfill (mirrors governanceMode). New code reads via the
  // resolver, never this column directly.
  enforcementMode          EnforcementMode? // null => WARN (see lib/enforcement-mode.ts)
  requireDistinctReviewer  Boolean         @default(false) /// @deprecated use governanceMode. Kept readable through one release cycle for dashboards + external clients. Runtime still derives an answer when governanceMode is null. Remove once no client references it.
  soloMode                 Boolean         @default(false) /// @deprecated use governanceMode. See requireDistinctReviewer.
  governanceMode           GovernanceMode? // Null only for rows predating the migration; runtime derives from the legacy flags when null. New writes always set this; new code should read this.
  // Phase 3 of the grounding-hint integration. When true, task_finish on a
  // debug-flavored task is gated on an evidence-ledger entry tagged with
  // the grounding session AND the session being at-or-past claim-evaluation.
  // Default false because the ledger lives on the agent's filesystem in
  // the common multi-host deployment; the backend cannot read it from
  // there. See docs/adr/0002-grounding-finish-gate.md.
  requireGroundingForDebug Boolean         @default(false)
  // Outbound push delivery for Signals. When `notificationWebhookUrl` is
  // set, every successful Signal create also POSTs the payload to that URL
  // (best-effort, one retry). Optional `notificationWebhookSecret` is used
  // to sign requests with `X-AgentTasks-Signature: sha256=<hmac>` so the
  // receiver can verify provenance. The secret is never returned in API
  // responses — callers see `hasNotificationWebhookSecret: boolean` only.
  // See docs/notification-webhooks.md.
  notificationWebhookUrl    String?
  notificationWebhookSecret String?
  // Per-task aggregate artifact caps. Null falls back to the env-var defaults
  // ARTIFACT_MAX_COUNT_PER_TASK (100) and ARTIFACT_MAX_TOTAL_BYTES_PER_TASK (50 MiB).
  // See docs/artifacts.md for details.
  artifactCountCap          Int?
  artifactBytesCap          Int?
  // Per-task aggregate attachment caps. Null falls back to the env-var defaults
  // ATTACHMENT_MAX_COUNT_PER_TASK (20) and ATTACHMENT_MAX_TOTAL_BYTES_PER_TASK (50 MiB).
  attachmentCountCap        Int?
  attachmentBytesCap        Int?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  team            Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tasks           Task[]
  workflows       Workflow[]
  boards          Board[]
  signals         Signal[]
  auditLogs       AuditLog[]
  toolInvocations ToolInvocation[]
  projectMembers  ProjectMember[]
  projectInvites  ProjectInvite[]

  @@unique([teamId, slug])
  @@map("projects")
}

// ── Project-level Sharing ────────────────────────────────────────────────────
// Per-project membership for users who are NOT in the project's team but
// have been invited to collaborate on this single project. Layered on top
// of TeamMember; access checks consider both sources. See
// services/team-access.ts for the resolution rules.

enum ProjectMemberRole {
  PROJECT_VIEWER
  PROJECT_CONTRIBUTOR
  PROJECT_ADMIN
}

model ProjectMember {
  id          String            @id @default(uuid())
  projectId   String
  userId      String
  role        ProjectMemberRole
  invitedById String
  createdAt   DateTime          @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation("ProjectMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User    @relation("ProjectMemberInviter", fields: [invitedById], references: [id])

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model ProjectInvite {
  id           String            @id @default(uuid())
  projectId    String
  // sha256 hex digest. Plain token is returned exactly once at creation
  // time and never persisted; same pattern as agent_tokens.tokenHash.
  tokenHash    String            @unique
  role         ProjectMemberRole
  createdById  String
  expiresAt    DateTime
  consumedAt   DateTime?
  consumedById String?
  createdAt    DateTime          @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy  User    @relation("ProjectInviteCreator", fields: [createdById], references: [id])
  consumedBy User?   @relation("ProjectInviteConsumer", fields: [consumedById], references: [id])

  @@index([projectId])
  @@index([expiresAt])
  @@map("project_invites")
}

// ── Workflows ────────────────────────────────────────────────────────────────

model Workflow {
  id         String   @id @default(uuid())
  projectId  String
  name       String
  definition Json // { states: [...], transitions: [...], policies: [...] }
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@map("workflows")
}

// ── Tasks ────────────────────────────────────────────────────────────────────

model Task {
  id          String       @id @default(uuid())
  projectId   String
  workflowId  String?
  title       String
  description String?
  status      String       @default("open")
  priority    TaskPriority @default(MEDIUM)

  // Human creator
  createdByUserId  String?
  // Agent creator
  createdByAgentId String?

  // Human claimant
  claimedByUserId  String?
  // Agent claimant
  claimedByAgentId String?

  claimedAt DateTime?
  dueAt     DateTime?

  // Review lock — only one reviewer at a time
  reviewClaimedByUserId  String?
  reviewClaimedByAgentId String?
  reviewClaimedAt        DateTime?

  // Template data (structured task info for agents)
  templateData Json? // { goal?, acceptanceCriteria?, context?, constraints?, scope?, outOfScope?, dependencies?, risk?, agentPrompt?, prefers?, taskType? }

  // Free-form per-task metadata, populated by the server. Currently stores
  // `{ debugFlavor: boolean }` to flag tasks that should be approached
  // through the grounding stack — set explicitly via the create-time
  // `debugFlavor` flag, or otherwise derived heuristically on first pickup /
  // start. Reserved for additional server-side annotations.
  metadata Json?

  // External system reference (e.g. Jira key "PROJ-123", GitHub issue "#42")
  externalRef String?
  // Free-form labels for categorization
  labels      String[] @default([])

  // Agent-populated fields
  branchName   String?
  prUrl        String?
  prNumber     Int?
  result       String?
  autoMergeSha String? // Merge commit SHA set by task_finish { autoMerge: true }; used for retry idempotency

  // Cross-repo deliverable override (ADR-0010 §5c). Null (the common case)
  // means the task's deliverable PR lives in `project.githubRepo`. When set,
  // it names the "owner/repo" that actually owns this task's PR lifecycle —
  // for tasks whose legitimate output is a PR in a different GitHub repo
  // (benchmark/measurement/docs tasks). The cross-repo PR guard compares
  // against this effective repo instead of always the project's; merge
  // automation hard-refuses when it diverges from project.githubRepo (the
  // foreign repo owns its own merge lifecycle). Settable at create time by
  // humans or agents; post-create changes are human-project-admin-only (see
  // PATCH /api/tasks/:id). See docs/workflow-preconditions.md.
  deliverableRepo String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project              Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workflow             Workflow?   @relation(fields: [workflowId], references: [id])
  createdByUser        User?       @relation("TaskCreator", fields: [createdByUserId], references: [id])
  createdByAgent       AgentToken? @relation("TaskAgentCreator", fields: [createdByAgentId], references: [id])
  claimedByUser        User?       @relation("TaskClaimant", fields: [claimedByUserId], references: [id])
  claimedByAgent       AgentToken? @relation("TaskAgentClaimant", fields: [claimedByAgentId], references: [id])
  reviewClaimedByUser  User?       @relation("TaskReviewer", fields: [reviewClaimedByUserId], references: [id])
  reviewClaimedByAgent AgentToken? @relation("TaskAgentReviewer", fields: [reviewClaimedByAgentId], references: [id])

  // Dependencies: this task blocks others / is blocked by others
  blocks    Task[] @relation("TaskDependency")
  blockedBy Task[] @relation("TaskDependency")

  comments    Comment[]
  attachments TaskAttachment[]
  artifacts   TaskArtifact[]
  signals     Signal[]
  auditLogs   AuditLog[]

  @@unique([projectId, externalRef])
  @@index([projectId])
  @@index([status])
  @@index([claimedByUserId])
  @@index([claimedByAgentId])
  @@index([projectId, status])
  @@index([labels], type: Gin)
  @@map("tasks")
}

model TaskAttachment {
  id     String @id @default(uuid())
  taskId String
  name   String
  // For uploaded files this is `/uploads/<uuid>.<ext>` and the bytes live on
  // the UPLOAD_DIR disk volume. For legacy URL-pointer attachments it is an
  // arbitrary external URL with no bytes stored by agent-tasks.
  url    String
  // Sniffed media type of an uploaded file (e.g. `image/png`, `text/markdown`).
  // Null for URL-pointer attachments.
  mimeType String?
  // Byte length of the stored file; `0` for URL-pointer attachments.
  sizeBytes Int @default(0)
  // `IMAGE` or `DOCUMENT`, validated in the route. Defaults to DOCUMENT so the
  // legacy URL-pointer create path and pre-existing rows stay valid after the
  // additive `prisma db push`.
  type            String  @default("DOCUMENT")
  createdByUserId String?
  createdAt       DateTime @default(now())

  task          Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdByUser User? @relation("AttachmentCreator", fields: [createdByUserId], references: [id])

  @@index([taskId])
  @@map("task_attachments")
}

// Typed, agent-produced task outputs (build logs, test reports, coverage, generated code, etc.).
// Distinct from TaskAttachment, which is a human-uploaded metadata pointer with no semantics.
model TaskArtifact {
  id               String   @id @default(uuid())
  taskId           String
  type             String // validated against ARTIFACT_TYPES enum in routes/services
  name             String
  description      String?
  content          String?  @db.Text // inline payload (subject to ARTIFACT_MAX_BYTES)
  url              String? // external pointer (S3, GH release, etc.) when content is not inline
  mimeType         String?
  sizeBytes        Int      @default(0)
  createdByUserId  String?
  createdByAgentId String?
  createdAt        DateTime @default(now())

  task           Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdByUser  User?       @relation("ArtifactCreator", fields: [createdByUserId], references: [id])
  createdByAgent AgentToken? @relation("ArtifactAgentCreator", fields: [createdByAgentId], references: [id])

  @@index([taskId])
  @@index([taskId, type])
  @@index([createdByAgentId])
  @@map("task_artifacts")
}

enum GovernanceMode {
  // Dual-control. The claimant cannot also be the merger. checkSelfMergeGate
  // blocks a self-merge attempt upstream. Replaces requireDistinctReviewer=true.
  REQUIRES_DISTINCT_REVIEWER
  // Async HITL. Agent may self-merge, but every human team member gets a
  // `self_merge_notice` signal so the merge is visible without gating. Replaces
  // (soloMode=false, requireDistinctReviewer=false) — the previously-ambiguous
  // middle tier that now has a distinct identity.
  AWAITS_CONFIRMATION
  // Single-actor project. No gates, no notifications. Replaces soloMode=true.
  AUTONOMOUS
}

// scorer-v2 (T5): per-project enforcement level for the confidence gate.
enum EnforcementMode {
  // Gate is advisory: the score is still computed and surfaced, but an agent is
  // never blocked. Use to fully opt a project out.
  OFF
  // Compute + surface + shadow-log would-blocks, but never block. The safe
  // rollout default — `null` resolves here, so existing projects start in WARN
  // without a backfill. The shadow audit/report quantifies blast radius here.
  WARN
  // Block agent claims below the threshold AND on a violated keystone
  // (ConfidenceResult.blocking) regardless of the threshold. Flip a project here
  // only after reviewing its shadow report (see docs/scorer-v2-enforcement.md).
  BLOCK
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ── Comments ─────────────────────────────────────────────────────────────────

model Comment {
  id            String   @id @default(uuid())
  taskId        String
  authorUserId  String?
  authorAgentId String?
  content       String
  createdAt     DateTime @default(now())

  task        Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorUser  User?       @relation("CommentAuthor", fields: [authorUserId], references: [id])
  authorAgent AgentToken? @relation("CommentAgentAuthor", fields: [authorAgentId], references: [id])

  @@index([taskId])
  @@map("comments")
}

// ── Boards ───────────────────────────────────────────────────────────────────

model Board {
  id        String   @id @default(uuid())
  projectId String
  name      String
  config    Json // { columns: [...], groupBy: ..., filters: [...] }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("boards")
}

// ── Agent Signals ───────────────────────────────────────────────────────────

model Signal {
  id               String    @id @default(uuid())
  type             String // "review_needed" | "changes_requested" | "task_approved" | "task_assigned"
  taskId           String
  projectId        String
  recipientAgentId String? // Target agent token (null for human)
  recipientUserId  String? // Target human user (null for agent)
  context          Json // Inline context per signal-payload-design.md
  acknowledgedAt   DateTime?
  createdAt        DateTime  @default(now())

  task           Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recipientAgent AgentToken? @relation("SignalRecipientAgent", fields: [recipientAgentId], references: [id])
  recipientUser  User?       @relation("SignalRecipientUser", fields: [recipientUserId], references: [id])

  @@index([recipientAgentId, acknowledgedAt])
  @@index([recipientUserId, acknowledgedAt])
  @@index([taskId])
  @@map("signals")
}

// ── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  projectId String?
  taskId    String?
  actorId   String? // userId
  action    String
  payload   Json     @default("{}")
  createdAt DateTime @default(now())

  // onDelete: SetNull is made explicit (it is also Prisma's default for an
  // optional relation, so this is SQL-equivalent today) to pin the audit-trail
  // retention guarantee: deleting a project/task/user nulls the ref and keeps
  // the audit row, rather than relying on the implicit default which a future
  // Prisma version could change.
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  actor   User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([taskId])
  @@index([actorId])
  @@map("audit_logs")
}

// ── Tool Invocations ─────────────────────────────────────────────────────────
//
// Idempotency log for side-effect MCP verbs (pull_requests_create, _merge,
// _comment, …). A client that wants at-most-once execution passes
// `idempotencyKey`; a retried call with the same (projectId, verb, key)
// replays the stored response instead of re-executing. A different payload
// under the same key is rejected with 409 to surface caller bugs instead of
// silently returning a stale response.
//
// v1 limitation: the row is inserted AFTER the side-effect executes, so two
// truly concurrent requests with the same key may still both run once before
// one loses the unique-constraint race. This covers the common case
// (retry-after-timeout) but not the pathological one. A later iteration can
// add an insert-first/execute-then-update pattern if the concurrent case
// ever becomes relevant.
model ToolInvocation {
  id             String   @id @default(uuid())
  projectId      String
  verb           String   @db.VarChar(64)
  idempotencyKey String   @db.VarChar(255)
  // sha256 hex of the canonicalized request payload (sans idempotencyKey).
  // Used to reject reuse of the same key with a different payload.
  payloadHash    String   @db.Char(64)
  responseBody   Json
  statusCode     Int
  createdAt      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, verb, idempotencyKey])
  @@index([createdAt]) // for TTL sweeps
  @@map("tool_invocations")
}

// ── Webhook Deliveries ────────────────────────────────────────────────────────
//
// Idempotency log for incoming GitHub webhook deliveries. GitHub guarantees
// at-least-once delivery and redelivers on non-2xx responses. Without dedup,
// a redelivery re-runs addTimelineComment and transition/audit logic, producing
// duplicate Comment rows and repeated audit entries.
//
// Pattern: claim-before-dispatch — the row is inserted BEFORE the fire-and-
// forget async block runs. A duplicate delivery with the same X-GitHub-Delivery
// id hits P2002 and is dropped at the route level without dispatching.
//
// Semantics are at-most-once: a claimed delivery is never released, so a
// delivery whose dispatch fails is not auto-reprocessed (the handlers are not
// idempotent — reprocessing would double-apply side effects). Failed
// dispatches are logged for operator follow-up.
//
// Not project-scoped: one GitHub delivery can fan out to multiple projects, so
// the table is keyed only on the globally unique deliveryId header value.
//
// Growth: a row is written per delivery and never auto-pruned today (mirrors
// the sibling tool_invocations table). A periodic TTL sweep for both tables is
// tracked as a follow-up.
model WebhookDelivery {
  id         String   @id @default(uuid())
  deliveryId String   @unique @db.VarChar(255) // X-GitHub-Delivery
  event      String   @db.VarChar(64)
  createdAt  DateTime @default(now())

  @@index([createdAt]) // supports a future TTL sweep
  @@map("webhook_deliveries")
}
