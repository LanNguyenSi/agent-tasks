FROM node:22-slim
RUN apt-get update -y && apt-get install -y openssl
WORKDIR /app
COPY package.json package-lock.json ./
COPY backend/package.json backend/package.json
COPY frontend/package.json frontend/package.json
RUN npm ci --workspace=backend
COPY backend/prisma backend/prisma
COPY backend/tsconfig.json backend/tsconfig.json
# Generate the Prisma client first so the data-normalization script can
# import @prisma/client. Then normalize any foreign task.status values
# (custom-workflow names, "abandoned") to the fixed 4-state set BEFORE
# running `db push` — otherwise the String→enum cast on `task.status`
# would fail. Both steps are idempotent.
CMD ["sh", "-c", "npx prisma generate --schema=/app/backend/prisma/schema.prisma && npx tsx /app/backend/prisma/normalize-task-status.ts && npx prisma db push --schema=/app/backend/prisma/schema.prisma --skip-generate --accept-data-loss"]
