classDiagram
    class Team {
        +string id
        +string name
    }
    class User {
        +string id
        +string email
        +string githubId
        +bool allowAgentPrCreate
        +bool allowAgentPrMerge
        +bool allowAgentPrComment
    }
    class TeamMember {
        +MemberRole role
    }
    class AgentToken {
        +string hashedToken
        +string[] scopes
        +DateTime expiresAt
    }
    class SsoConnection {
        +string emailDomain
        +string clientSecretEnc
    }
    class Project {
        +string githubRepo
        +int confidenceThreshold
        +GovernanceMode governanceMode
        +bool soloMode_deprecated
        +bool requireDistinctReviewer_deprecated
        +bool requireGroundingForDebug
    }
    class ProjectMember {
        +ProjectMemberRole role
    }
    class ProjectInvite {
        +string hashedToken
        +DateTime expiresAt
    }
    class Workflow {
        +bool isDefault
        +Json definition
    }
    class Board {
        +Json columns
        +Json filters
    }
    class Task {
        +string status
        +TaskPriority priority
        +string branchName
        +string prUrl
        +int prNumber
        +Json templateData
        +Json metadata
    }
    class TaskDependency {
        +string blockerTaskId
        +string blockedTaskId
    }
    class TaskArtifact {
        +string type
        +string content
        +string url
    }
    class Comment
    class Signal {
        +string type
        +string recipientUserId
        +string recipientAgentId
        +DateTime acknowledgedAt
    }
    class AuditLog {
        +string action
        +Json payload
    }
    class ToolInvocation {
        +string verb
        +string idempotencyKey
        +string payloadHash
    }

    Team "1" o-- "*" TeamMember
    Team "1" o-- "*" AgentToken
    Team "1" o-- "0..1" SsoConnection
    Team "1" o-- "*" Project
    User "1" o-- "*" TeamMember
    Project "1" o-- "*" ProjectMember
    Project "1" o-- "*" ProjectInvite
    Project "1" o-- "*" Workflow
    Project "1" o-- "*" Board
    Project "1" o-- "*" Task
    Project "1" o-- "*" AuditLog
    Project "1" o-- "*" ToolInvocation
    User "1" o-- "*" ProjectMember
    Task "1" o-- "*" TaskArtifact
    Task "1" o-- "*" Comment
    Task "1" o-- "*" Signal
    Task "1" o-- "*" AuditLog
    Task "1" -- "*" TaskDependency : blocks
    Task "1" -- "*" TaskDependency : blockedBy
    User "1" o-- "*" Signal : recipientUser
    AgentToken "1" o-- "*" Signal : recipientAgent
