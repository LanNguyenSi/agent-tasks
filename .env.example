# Backend
DATABASE_URL=postgresql://agent_tasks:agent_tasks@localhost:5432/agent_tasks
# Optional for GitHub connect/sync features:
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Required. Must be at least 32 characters. Generate one with:
#   openssl rand -hex 32
SESSION_SECRET=
PORT=3001
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
# Optional: GitHub webhook signature verification (required in production)
GITHUB_WEBHOOK_SECRET=
# Number of trusted reverse-proxy hops in front of the backend. Set to the
# count of proxies that append to X-Forwarded-For; the rate limiter reads the
# real client IP that many entries in from the right. Prod sits behind a
# single Traefik hop, so use 1. Leave 0 (default) only when nothing proxies the
# backend, in which case the limiter keys on the raw socket peer address.
TRUSTED_PROXY_HOPS=1

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
